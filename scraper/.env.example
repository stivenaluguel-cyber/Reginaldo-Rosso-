# ============================================================
# .env.example — Copie para .env e preencha com seus dados
# ============================================================

# ── Banco de Dados PostgreSQL ────────────────────────────────────
# Formato: postgresql://usuario:senha@host:porta/banco
DATABASE_URL=postgresql://usuario:senha@localhost:5432/caixa_imoveis

# ── AWS S3 ────────────────────────────────────────────────────────
AWS_ACCESS_KEY_ID=AKIAIOSFODNN7EXAMPLE
AWS_SECRET_ACCESS_KEY=wJalrXUtnFEMI/K7MDENG/bPxRfiCYEXAMPLEKEY
AWS_REGION=us-east-1
S3_BUCKET_NAME=reginaldo-rosso-docs

# ── CAPTCHA (escolha um provedor) ────────────────────────────────
# Opções: "capsolver" ou "2captcha"
CAPTCHA_PROVIDER=capsolver

# Chave CapSolver (https://capsolver.com)
CAPSOLVER_API_KEY=CAP-XXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXX

# Chave 2Captcha (https://2captcha.com) — preencher se usar 2captcha
TWOCAPTCHA_API_KEY=

# ── Configurações do Scraper ─────────────────────────────────────
# Número de abas paralelas do Playwright (recomendado: 2-5)
MAX_WORKERS=3

# Número máximo de tentativas por imóvel
MAX_RETRIES=3

# Executar Playwright sem interface gráfica (true no servidor, false no Mac para debug)
HEADLESS=true

# Timeout por página em milissegundos (60000 = 60s)
TIMEOUT_MS=60000
